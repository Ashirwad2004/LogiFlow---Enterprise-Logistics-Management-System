PROJECT_NAME="LogiFlow"
API_V1_STR="/api/v1"
SECRET_KEY="supersecretjwtkeythatshouldbechangedinproduction"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configs
